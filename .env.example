# FSI Multi-Agent demo — environment template.
#
# This asset deploys entirely from variables; NO resource names are hardcoded in code.
# Copy to `.env` for local reference, but the canonical store during deployment is the
# azd environment (`azd env set NAME value`). `deploy.ps1` and
# `scripts/set_azd_env_from_infra.ps1` populate most of these for you from the infra
# outputs — the only values you must supply yourself are marked "YOU SET".
#
# ---------------------------------------------------------------------------
# 1. Deployment identity / target (YOU SET before `deploy.ps1`)
# ---------------------------------------------------------------------------
# Short name that drives resource naming and the resource group (rg-<name>). 3-20 chars.
AZURE_ENV_NAME=fsi-demo
# Azure region with Foundry model quota for the model deployments below.
AZURE_LOCATION=eastus2
# Your Azure AD object id, granted Foundry data-plane access for portal testing
# (get it with: az ad signed-in-user show --query id -o tsv).
AZURE_PRINCIPAL_ID=

# ---------------------------------------------------------------------------
# 2. Infra outputs (AUTO-populated by deploy.ps1 from the bicep deployment)
# ---------------------------------------------------------------------------
AZURE_RESOURCE_GROUP=
AZURE_AI_PROJECT_ENDPOINT=
AZURE_STORAGE_BLOB_ENDPOINT=
AZURE_CONTAINER_REGISTRY_NAME=
AZURE_CONTAINER_REGISTRY_ENDPOINT=
AZURE_CLIENT_ID=
APPLICATIONINSIGHTS_CONNECTION_STRING=
API_URL=
PORTAL_URL=

# ---------------------------------------------------------------------------
# 3. Skill / toolbox provisioning (agents/scripts/*)
# ---------------------------------------------------------------------------
# = AZURE_AI_PROJECT_ENDPOINT. Required; scripts fail fast if unset.
PROJECT_ENDPOINT=
# Immutable commit in anthropics/financial-services the skills are pinned to.
ANTHROPIC_SKILLS_REF=4aa51ed3d379731f8f9beff498d749580372699c

# ---------------------------------------------------------------------------
# 4. Hosted-agent deployment (agents/hosted/_azd, consumed by azure.yaml)
#    AUTO-populated by scripts/set_azd_env_from_infra.ps1.
# ---------------------------------------------------------------------------
FOUNDRY_PROJECT_ENDPOINT=
# Model deployment name the agents run on (must exist on the account; see infra).
AZURE_AI_MODEL_DEPLOYMENT_NAME=gpt-5.1
# Per-scenario toolbox MCP endpoints. Derived from PROJECT_ENDPOINT + toolbox name.
TOOLBOX_ENDPOINT_EQUITY=
TOOLBOX_ENDPOINT_IB=
TOOLBOX_ENDPOINT_LBO=
STORAGE_BLOB_ENDPOINT=
ARTIFACTS_CONTAINER=artifacts
FSI_STORE=false
ENABLE_INSTRUMENTATION=false

# ---------------------------------------------------------------------------
# 5. SEC EDGAR remote MCP tool (OPTIONAL — public-company filings)
#    Leave SEC_EDGAR_MCP_URL empty to deploy without the SEC tool.
# ---------------------------------------------------------------------------
# YOU SET: a real contact string; the SEC requires it for automated EDGAR access.
SEC_EDGAR_USER_AGENT=Your Name (you@example.com)
# AUTO-populated when the SEC EDGAR MCP Container App is deployed.
SEC_EDGAR_MCP_URL=
# AUTO-generated shared secret injected by the Foundry gateway; stored in Key Vault.
FSI_MCP_KEY=
FSI_MCP_KEY_HEADER=x-fsi-mcp-key
# "true" also allows the slower full-filing / full-statement tools.
SEC_EDGAR_DEEP_TOOLS=false

# ---------------------------------------------------------------------------
# 6. Portal build (baked into the Next.js image at build time)
# ---------------------------------------------------------------------------
NEXT_PUBLIC_API_BASE_URL=
